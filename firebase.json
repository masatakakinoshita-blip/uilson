{
  "hosting": [
    {
      "target": "production",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/chat", "function": { "functionId": "chat", "region": "asia-northeast1" } },
        { "source": "/api/cron", "function": { "functionId": "cron", "region": "asia-northeast1" } },
        { "source": "/api/generate-skill", "function": { "functionId": "generateskill", "region": "asia-northeast1" } },
        { "source": "/api/generate-slides", "function": { "functionId": "generateslides", "region": "asia-northeast1" } },
        { "source": "/api/google-oauth", "function": { "functionId": "googleoauth", "region": "asia-northeast1" } },
        { "source": "/api/google-refresh", "function": { "functionId": "googlerefresh", "region": "asia-northeast1" } },
        { "source": "/api/ms-oauth", "function": { "functionId": "msoauth", "region": "asia-northeast1" } },
        { "source": "/api/parse-template", "function": { "functionId": "parsetemplate", "region": "asia-northeast1" } },
        { "source": "/api/skills", "function": { "functionId": "skills", "region": "asia-northeast1" } },
        { "source": "/api/slack-messages", "function": { "functionId": "slackmessages", "region": "asia-northeast1" } },
