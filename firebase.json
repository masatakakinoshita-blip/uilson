        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "staging",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/chat", "run": { "serviceId": "uilson-api", "region": "asia-northeast1" } },
        { "source": "/api/health", "run": { "serviceId": "uilson-api", "region": "asia-northeast1" } },
        { "source": "/api/memory/**", "run": { "serviceId": "uilson-api", "region": "asia-northeast1" } },
        { "source": "/api/suggest/**", "run": { "serviceId": "uilson-api", "region": "asia-northeast1" } },
        { "source": "/api/skills", "function": { "functionId": "skills", "region": "asia-northeast1" } },
        { "source": "/api/generate-skill", "function": { "functionId": "generateskill", "region": "asia-northeast1" } },
        { "source": "/api/generate-slides", "function": { "functionId": "generateslides", "region": "asia-northeast1" } },
        { "source": "/api/google-oauth", "function": { "functionId": "googleoauth", "region": "asia-northeast1" } },
        { "source": "/api/google-refresh", "function": { "functionId": "googlerefresh", "region": "asia-northeast1" } },
        { "source": "/api/ms-oauth", "function": { "functionId": "msoauth", "region": "asia-northeast1" } },
        { "source": "/api/parse-template", "function": { "functionId": "parsetemplate", "region": "asia-northeast1" } },
        { "source": "/api/slack-messages", "function": { "functionId": "slackmessages", "region": "asia-northeast1" } },
        { "source": "/api/slack-oauth", "function": { "functionId": "slackoauth", "region": "asia-northeast1" } },
        { "source": "/api/slack-userinfo", "function": { "functionId": "slackuserinfo", "region": "asia-northeast1" } },
        { "source": "/api/zoom-oauth", "function": { "functionId": "zoomoauth", "region": "asia-northeast1" } },
        { "source": "/api/zoom-meetings", "function": { "functionId": "zoommeetings", "region": "asia-northeast1" } },
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20"
    }
  ]
}
