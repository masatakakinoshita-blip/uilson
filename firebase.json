{
  "hosting": [
    {
      "target": "production",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/chat", "function": "chat" },
        { "source": "/api/cron", "function": "cron" },
        { "source": "/api/generate-skill", "function": "generateskill" },
        { "source": "/api/generate-slides", "function": "generateslides" },
        { "source": "/api/google-oauth", "function": "googleoauth" },
        { "source": "/api/google-refresh", "function": "googlerefresh" },
        { "source": "/api/ms-oauth", "function": "msoauth" },
        { "source": "/api/parse-template", "function": "parsetemplate" },
        { "source": "/api/skills", "function": "skills" },
        { "source": "/api/slack-messages", "function": "slackmessages" },
        { "source": "/api/slack-oauth", "function": "slackoauth" },
        { "source": "/api/slack-userinfo", "function": "slackuserinfo" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "staging",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/chat", "function": "chat" },
        { "source": "/api/cron", "function": "cron" },
        { "source": "/api/generate-skill", "function": "generateskill" },
        { "source": "/api/generate-slides", "function": "generateslides" },
        { "source": "/api/google-oauth", "function": "googleoauth" },
        { "source": "/api/google-refresh", "function": "googlerefresh" },
        { "source": "/api/ms-oauth", "function": "msoauth" },
        { "source": "/api/parse-template", "function": "parsetemplate" },
        { "source": "/api/skills", "function": "skills" },
        { "source": "/api/slack-messages", "function": "slackmessages" },
        { "source": "/api/slack-oauth", "function": "slackoauth" },
        { "source": "/api/slack-userinfo", "function": "slackuserinfo" },
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20"
    }
  ]
}
